@model Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="page-header">
    <h1>@Model.Title</h1>
    <a asp-action="Index" class="btn btn-sm">← Back to list</a>
</div>

<div class="detail-card">
    <dl class="detail-grid">
        <dt>Author</dt>      <dd>@Model.Author?.FullName</dd>
        <dt>ISBN</dt>        <dd class="mono">@Model.Isbn</dd>
        <dt>Published</dt>   <dd>@Model.PublishedYear</dd>
        <dt>Borrowings</dt>  <dd>@Model.Borrowings.Count total</dd>
    </dl>
</div>

<div class="section-header">
    <h2>Borrowing History</h2>
    <a asp-controller="Borrowings" asp-action="Create" asp-route-bookId="@Model.Id" class="btn btn-primary btn-sm">
        + New Borrowing
    </a>
</div>

@if (!Model.Borrowings.Any())
{
    <p class="empty-state">This book has never been borrowed.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Borrower</th>
                <th>Borrowed At</th>
                <th>Returned At</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model.Borrowings.OrderByDescending(x => x.BorrowedAt))
            {
                <tr>
                    <td>@b.BorrowerName</td>
                    <td>@b.BorrowedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(b.ReturnedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                    <td>
                        @if (b.IsReturned)
                        {
                            <span class="badge badge-success">Returned</span>
                        }
                        else
                        {
                            <span class="badge badge-warning">Out</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
