@model Book
@{
    ViewData["Title"] = "Add Book";
}

<div class="page-header">
    <h1>Add New Book</h1>
    <a asp-action="Index" class="btn btn-sm">← Back to list</a>
</div>

<div class="form-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label asp-for="Title">Title</label>
            <input asp-for="Title" class="form-control" placeholder="e.g. The Name of the Wind" />
            <span asp-validation-for="Title" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Isbn">ISBN</label>
            <input asp-for="Isbn" class="form-control mono" placeholder="e.g. 978-0-7564-0407-9" />
            <span asp-validation-for="Isbn" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="PublishedYear">Published Year</label>
            <input asp-for="PublishedYear" type="number" class="form-control" placeholder="e.g. 2007" />
            <span asp-validation-for="PublishedYear" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="AuthorId">Author</label>
            <select asp-for="AuthorId" asp-items="ViewBag.AuthorId" class="form-control">
                <option value="">— Select an author —</option>
            </select>
            <span asp-validation-for="AuthorId" class="field-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Book</button>
            <a asp-action="Index" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
