@model IEnumerable<Author>
@{
    ViewData["Title"] = "Authors";
}

<div class="page-header">
    <h1>Authors</h1>
</div>

@if (!Model.Any())
{
    <p class="empty-state">No authors yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Books</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var author in Model)
            {
                <tr>
                    <td><strong>@author.FullName</strong></td>
                    <td>@author.Books.Count</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@author.Id" class="btn btn-sm">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
